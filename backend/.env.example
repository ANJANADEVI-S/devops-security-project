# Flask Backend Configuration
PORT=5000
JWT_SECRET_KEY=super-secret-jwt-key-change-in-production

# Vault Configuration
VAULT_ADDR=http://127.0.0.1:8200
VAULT_ROLE_ID=your-role-id-from-vault
VAULT_SECRET_ID=your-secret-id-from-vault

# Set to "true" to use mock vault (no real Vault needed)
VAULT_MOCK_MODE=true

# Default access deadline in hours
DEFAULT_DEADLINE_HOURS=24
